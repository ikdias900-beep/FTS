{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/fts-lab/experiment_manifest.schema.json",
  "title": "FTS Lab Experiment Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "run_id",
    "artifact_kind",
    "epistemic_status",
    "task_ids",
    "claim_ids",
    "source_ids",
    "assumption_ids",
    "created_at_utc",
    "command",
    "parameters",
    "seed",
    "git",
    "environment",
    "inputs",
    "outputs",
    "status",
    "error",
    "implementation"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "manifest_id": { "type": "string", "pattern": "^ART-[A-Z0-9-]+$" },
    "run_id": { "type": "string", "pattern": "^EXP-[A-Z0-9-]+$" },
    "artifact_kind": { "type": "string" },
    "epistemic_status": {
      "anyOf": [
        { "type": "null" },
        { "type": "string", "enum": ["R", "C", "E", "A"] }
      ]
    },
    "task_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^TASK-[A-Z0-9-]+$" },
      "minItems": 1,
      "uniqueItems": true
    },
    "claim_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^CLM-[A-Z0-9-]+$" },
      "uniqueItems": true
    },
    "source_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^SRC-[A-Z0-9-]+$" },
      "uniqueItems": true
    },
    "assumption_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^ASM-[A-Z0-9-]+$" },
      "uniqueItems": true
    },
    "created_at_utc": { "type": "string", "format": "date-time" },
    "command": { "type": "string", "minLength": 1 },
    "parameters": { "type": "object" },
    "seed": { "type": ["integer", "null"] },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commit", "branch", "detached", "dirty"],
      "properties": {
        "commit": { "type": ["string", "null"] },
        "branch": { "type": ["string", "null"] },
        "detached": { "type": "boolean" },
        "dirty": { "type": "boolean" }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["python_version", "platform", "dependency_lock_sha256"],
      "properties": {
        "python_version": { "type": "string" },
        "platform": { "type": "string" },
        "dependency_lock_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/checksummed_path" },
      "minItems": 1
    },
    "outputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/checksummed_path" },
      "minItems": 1
    },
    "status": { "type": "string", "enum": ["completed", "failed"] },
    "error": { "type": ["string", "null"] },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "version"],
      "properties": {
        "package": { "type": "string" },
        "version": { "type": "string" }
      }
    }
  },
  "$defs": {
    "checksummed_path": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}
